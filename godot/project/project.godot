; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="SCPS"
run/main_scene="res://main/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[debug]

file_logging/enable_file_logging=true
file_logging/log_path="user://logs/godot.log"
file_logging/max_log_files=5

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/size/mode=3
; étirement canvas_items : requis pour l'ÉCHELLE UI des options (content_scale_factor).
; factor par défaut 1.0 = rendu identique à avant ; l'option 125/150 % scale tout.
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[autoload]

Sim="*res://autoload/sim.gd"
Sound="*res://audio/sound.gd"
ECUtilities="*uid://cip7vyqyn45sf"

[gui]

; tooltip natif NEUTRALISÉ à la source (le set_setting runtime de main.gd ne
; suffisait pas : « double hover » sur les onglets du rail, retour joueur
; 2026-07-10) — le TooltipServer est le SEUL rendu de tooltip.
timers/tooltip_delay_sec=100000.0

[editor_plugins]

enabled=PackedStringArray("res://addons/easy_charts/plugin.cfg", "res://addons/medusa/plugin.cfg")

[internationalization]

locale/translations=PackedStringArray("res://i18n/ui.fr.translation", "res://i18n/ui.en.translation")
locale/fallback="fr"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
