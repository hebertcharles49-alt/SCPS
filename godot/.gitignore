# Le clone godot-cpp (régénérable : git clone -b 4.3 …) — pas dans le repo SCPS.
godot-cpp/

# Artefacts de build (par plateforme : on les rebâtit avec scons).
build/
project/bin/
*.os
*.o
*.obj
.sconsign.dblite

# Cache de l'éditeur Godot.
project/.godot/
project/.import/
# Sidecars d'import (.import) : le projet charge les PNG en Image brute (hors
# pipeline d'import) — aucun n'est suivi ; l'éditeur les régénère à l'ouverture.
*.import
# UID Godot 4 (.uid) : métadonnées régénérées par l'éditeur (même statut que .import) — non suivies.
*.uid

# Captures headless des scènes de vérification/probes (shot/rv/nb/canopy/town/diplo/… — régénérables).
# Les VRAIS assets vivent dans les sous-dossiers (pack/, art/, ui/, addons/) — ce motif ne touche QUE la racine.
project/*.png
